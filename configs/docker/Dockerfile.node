FROM golang:1.21-alpine AS builder

RUN apk add --no-cache gcc musl-dev openssl-dev

WORKDIR /build

COPY go.mod go.sum ./
COPY cmd/mpc-node ./cmd/mpc-node
COPY pkg ./pkg
COPY api ./api

RUN go build -o mpc_node ./cmd/mpc-node

FROM alpine:3.19

RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=builder /build/mpc_node ./

ENV NODE_ID=1
ENV CLUSTER_ID=default
ENV THRESHOLD=3
ENV TOTAL_NODES=5
ENV LISTEN_ADDR=:7001

EXPOSE 7001

ENTRYPOINT ["./mpc_node"]
